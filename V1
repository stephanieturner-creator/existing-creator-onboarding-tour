<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Communities — Creator Onboarding Tour v8</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#F0F1F3;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
:root{
  --teal:#00C8C8;--teal-light:#E0FAFA;--teal-dark:#008A8A;
  --g50:#F5F5F4;--g100:#EEEDE9;--g200:#E2E0DB;--g300:#C8C6C0;
  --g500:#8A8880;--g700:#4A4845;--g900:#1A1916;
  --white:#FFFFFF;--green:#38A169;--amber:#D69E2E;
  --border:1px solid #E2E0DB;--font:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
}
.shell{display:flex;height:680px;width:100%;max-width:960px;background:var(--g50);border-radius:12px;overflow:hidden;border:1px solid var(--g200);font-family:var(--font);box-shadow:0 4px 24px rgba(0,0,0,.08);position:relative}
.leftnav{width:220px;background:var(--white);border-right:var(--border);display:flex;flex-direction:column;padding:0;flex-shrink:0}
.nav-logo{display:flex;align-items:center;gap:8px;padding:16px 16px 12px;border-bottom:var(--border)}
.nav-logo-icon{width:28px;height:28px;border-radius:7px;background:var(--teal);display:flex;align-items:center;justify-content:center}
.nav-logo-icon svg{width:16px;height:16px;fill:none;stroke:#fff;stroke-width:2}
.nav-logo-name{font-size:14px;font-weight:700;color:var(--g900)}.nav-logo-name span{font-weight:400}
.nav-items{padding:10px 10px 0;flex:1}
.nav-get-started{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;background:var(--teal-light);margin-bottom:4px;cursor:pointer;border:1px solid #99E6E6}
.nav-gs-icon{width:32px;height:32px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nav-gs-icon svg{width:16px;height:16px;fill:none;stroke:#fff;stroke-width:2}
.nav-gs-text strong{display:block;font-size:13px;font-weight:600;color:var(--teal-dark)}
.nav-gs-text span{font-size:11px;color:var(--teal-dark)}
.nav-gs-badge{margin-left:auto;width:20px;height:20px;border-radius:50%;background:var(--teal);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;font-size:13px;color:var(--g700);cursor:pointer;margin-bottom:2px;transition:background .12s}
.nav-item:hover{background:var(--g50)}
.nav-item.active{background:var(--teal-light);color:var(--teal-dark);font-weight:600}
.nav-item svg{width:16px;height:16px;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:1.8}
.nav-bottom{padding:12px 10px;border-top:var(--border);margin-top:auto}
.nav-settings{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;font-size:13px;color:var(--g700);cursor:pointer}
.nav-settings svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;flex-shrink:0}
.main-wrap{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{background:var(--white);border-bottom:var(--border);padding:0 20px;height:48px;display:flex;align-items:center;gap:10px;flex-shrink:0}
.topbar-logo-icon{width:24px;height:24px;border-radius:6px;background:var(--teal);display:flex;align-items:center;justify-content:center}
.topbar-logo-icon svg{width:13px;height:13px;fill:none;stroke:#fff;stroke-width:2}
.topbar-brand{font-size:14px;font-weight:700;color:var(--g900)}.topbar-brand span{font-weight:400}
.topbar-spacer{flex:1}
.topbar-notif svg,.topbar-msg svg{width:16px;height:16px;stroke:var(--g500);fill:none;stroke-width:1.8}
.topbar-notif,.topbar-msg{width:32px;height:32px;display:flex;align-items:center;justify-content:center}
.topbar-avatar{width:28px;height:28px;border-radius:50%;background:var(--teal-light);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--teal-dark);border:1px solid #99E6E6}
.content{flex:1;overflow-y:auto}
.hero-banner{height:120px;background:linear-gradient(120deg,#2C5F5A 0%,#6B2D2D 100%);padding:24px 28px;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden}
.hero-banner::after{content:'';position:absolute;right:-40px;top:-40px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04)}
.hero-h{font-size:20px;font-weight:700;color:#fff;margin-bottom:4px}
.hero-sub{font-size:13px;color:rgba(255,255,255,.75)}
.stat-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;padding:20px 24px 0}
.stat-card{background:var(--white);border:var(--border);border-radius:10px;padding:16px}
.stat-icon svg{width:20px;height:20px;stroke:var(--teal);fill:none;stroke-width:1.8;margin-bottom:8px}
.stat-label{font-size:11px;color:var(--g500);margin-bottom:4px}
.stat-num{font-size:22px;font-weight:700;color:var(--g900);margin-bottom:6px}
.stat-link{font-size:12px;color:var(--teal-dark);cursor:pointer}
.two-col{display:grid;grid-template-columns:minmax(0,1fr) 280px;gap:16px;padding:20px 24px}
.section-title{font-size:13px;font-weight:600;color:var(--g900);margin-bottom:12px}
.activity-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--white);border:var(--border);border-radius:8px;margin-bottom:6px}
.act-icon{width:32px;height:32px;border-radius:8px;background:var(--teal-light);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.act-icon svg{width:14px;height:14px;stroke:var(--teal-dark);fill:none;stroke-width:2}
.act-body{flex:1}
.act-name{font-size:12px;color:var(--g900)}.act-name strong{font-weight:600}
.act-sub{font-size:11px;color:var(--g500);margin-top:1px}
.act-time{font-size:11px;color:var(--g500);flex-shrink:0}
.act-btn{font-size:11px;color:var(--teal-dark);border:1px solid var(--g200);padding:3px 8px;border-radius:5px;cursor:pointer;background:var(--white);flex-shrink:0}
.quick-actions-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.qa-btn{background:var(--white);border:var(--border);border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:8px;cursor:pointer;font-size:12px;font-weight:500;transition:border-color .12s}
.qa-btn svg{width:14px;height:14px;fill:none;stroke-width:2;flex-shrink:0}
.qa-btn.blue{background:#EFF6FF;border-color:#BFDBFE;color:#1D4ED8}.qa-btn.blue svg{stroke:#1D4ED8}
.qa-btn.purple{background:#F5F3FF;border-color:#DDD6FE;color:#6D28D9}.qa-btn.purple svg{stroke:#6D28D9}
.qa-btn.orange{background:#FFF7ED;border-color:#FED7AA;color:#C2410C}.qa-btn.orange svg{stroke:#C2410C}
.qa-btn.green{background:#F0FDF4;border-color:#BBF7D0;color:#15803D}.qa-btn.green svg{stroke:#15803D}
.top-course{background:var(--white);border:var(--border);border-radius:8px;padding:12px;margin-bottom:12px}
.top-course-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--g500);margin-bottom:8px;display:flex;align-items:center;gap:4px}
.communities-section{background:var(--white);border:var(--border);border-radius:8px;padding:12px}
.comm-icon{width:28px;height:28px;border-radius:6px;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.comm-item{display:flex;align-items:center;gap:8px;padding:6px 0}
.overlay{position:absolute;inset:0;background:rgba(15,15,14,.5);display:flex;align-items:center;justify-content:center;z-index:20;border-radius:12px}
.modal{background:#F8F9FA;border-radius:20px;width:408px;max-width:calc(100% - 32px);overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.22)}
.modal-step{display:none}.modal-step.active{display:block}
.mdots{display:flex;justify-content:center;gap:6px;padding:18px 0 0}
.mdot{width:7px;height:7px;border-radius:50%;background:var(--g200);transition:all .25s}
.mdot.active{background:var(--teal);width:22px;border-radius:99px}
.mhero{padding:18px 28px 0;text-align:center}
.micon{width:56px;height:56px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;margin:0 auto 12px}
.micon svg{width:26px;height:26px;stroke:#fff;fill:none;stroke-width:2}
.mh{font-size:19px;font-weight:700;color:var(--g900);line-height:1.25;margin-bottom:6px}
.msub{font-size:13px;color:var(--g500);line-height:1.6;margin-bottom:16px}
.mstats{display:flex;gap:8px;margin:0 24px 14px}
.mstat{flex:1;background:var(--white);border:var(--border);border-radius:10px;padding:11px 10px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.mstat-emoji{font-size:18px;margin-bottom:4px}
.mstat-n{font-size:17px;font-weight:700;color:var(--g900)}
.mstat-l{font-size:10px;color:var(--g500);margin-top:2px}
.mtile-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:0 24px 6px}
.mtile{background:var(--white);border:1px solid var(--g200);border-radius:14px;padding:16px 14px 14px;cursor:pointer;transition:border-color .15s,box-shadow .15s;box-shadow:0 1px 3px rgba(0,0,0,.04);position:relative;overflow:hidden;display:flex;flex-direction:column;gap:8px;min-height:110px}
.mtile:hover{border-color:var(--teal);box-shadow:0 3px 10px rgba(0,200,200,.15)}
.mtile-emoji{font-size:24px;line-height:1}
.mtile-t{font-size:13px;font-weight:700;color:var(--g900);line-height:1.2}
.mtile-s{font-size:11px;color:var(--g500);line-height:1.4}
.mtile-arr{font-size:14px;color:var(--teal-dark);margin-top:auto;align-self:flex-end}
.mtile-locked{cursor:default}
.mtile-locked:hover{border-color:var(--g200);box-shadow:0 1px 3px rgba(0,0,0,.04)}
.locked-fog{position:absolute;inset:0;background:rgba(248,249,250,.86);display:flex;align-items:center;justify-content:center;border-radius:14px}
.locked-pill{display:inline-flex;align-items:center;gap:5px;background:#FEF9C3;color:#78450A;font-size:10px;font-weight:700;padding:5px 10px;border-radius:99px;border:1px solid #F6D860}
.mfooter{display:flex;align-items:center;justify-content:space-between;padding:14px 24px 20px;gap:10px}
.mbtn-skip{background:none;border:none;font-size:11px;color:#C8C6C0;cursor:pointer;font-family:var(--font);padding:0;letter-spacing:.01em}
.mbtn-skip:hover{color:var(--g500)}
.mbtn-back{background:var(--white);border:1.5px solid #00C8C8;color:#008A8A;font-size:13px;font-weight:600;padding:9px 18px;border-radius:9px;cursor:pointer;font-family:var(--font);transition:background .15s}
.mbtn-back:hover{background:#E0FAFA}
.mbtn-go{background:#00C8C8;color:#fff;border:none;font-size:13px;font-weight:600;padding:10px 22px;border-radius:9px;cursor:pointer;font-family:var(--font);transition:opacity .15s}
.mbtn-go:hover{opacity:.88}
.mfinal-wrap{padding:24px 28px 8px;text-align:center}
.mfinal-icon{width:68px;height:68px;border-radius:50%;background:var(--teal-light);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;border:2px solid #99E6E6;font-size:32px}
.mfinal-tag{display:inline-block;background:var(--teal-light);color:var(--teal-dark);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:4px 12px;border-radius:99px;border:1px solid #99E6E6;margin-bottom:14px}
.mfinal-cta{display:block;width:calc(100% - 48px);margin:18px 24px 4px;background:#00C8C8;color:#fff;border:none;font-size:14px;font-weight:600;padding:14px 20px;border-radius:10px;cursor:pointer;font-family:var(--font);transition:opacity .15s}
.mfinal-cta:hover{opacity:.88}
.toast{position:absolute;bottom:18px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--g900);color:#fff;font-size:12px;font-weight:500;padding:9px 16px;border-radius:8px;display:flex;align-items:center;gap:8px;opacity:0;transition:all .3s;z-index:40;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.tchk{width:16px;height:16px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}
</style>
</head>
