  </div>

  <div class="toast" id="toast">
    <div class="tchk">✓</div>
    <span id="tmsg">Done!</span>
  </div>
</div>

<script>
function goStep(n){
  for(var i=1;i<=3;i++){
    var s=document.getElementById('ms'+i);
    if(s) s.className='modal-step'+(i===n?' active':'');
  }
}
function closeModal(){
  var o=document.getElementById('overlay');
  if(o){o.style.opacity='0';o.style.transition='opacity .3s';setTimeout(function(){o.style.display='none'},300);}
}
function showToast(msg){
  var t=document.getElementById('toast');
  document.getElementById('tmsg').textContent=msg;
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show')},3000);
}
</script>
</body>
</html>
